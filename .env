# Local development uses SQLite by default.
DATABASE_URL="file:./dev.db"

# Production recommendation:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/caretaker_compliance"

# Optional Google Calendar integration placeholders.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/google/callback"

# File storage mode.
# local = public/uploads
# production should move this to Supabase Storage, S3, or Google Drive.
FILE_STORAGE_MODE="local"
