datasource db {

  provider = "postgresql"

  url      = env("DATABASE_URL")

}

generator client {

  provider = "prisma-client-js"
}


/*
Production note:
For PostgreSQL, change datasource provider to "postgresql" and use a Postgres DATABASE_URL.
*/

enum UserRole {
  ADMIN
  COMMITTEE
  CARETAKER
  STRATA_MANAGER
  CONTRACTOR
  OWNER_VIEWER
}

enum TaskStatus {
  SCHEDULED
  ACTIONED
  COMPLETED
  NEEDS_FOLLOW_UP
  ESCALATED_TO_COMMITTEE
  NOT_REQUIRED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum PaymentStatus {
  PASS
  WARNING
  BLOCKED
  PENDING
}

enum DocumentCategory {
  PHOTO_EVIDENCE
  QUOTE
  INVOICE
  VARIATION_APPROVAL
  COMMITTEE_APPROVAL
  CONTRACTOR_REPORT
  COMPLIANCE_CERTIFICATE
  EMAIL_EVIDENCE
  OTHER
}

enum Visibility {
  INTERNAL_ONLY
  COMMITTEE_ONLY
  OWNER_VISIBLE
  RESTRICTED
}

model User {
  id        String   @id @default(cuid())
  fullName  String
  email     String   @unique
  role      UserRole @default(COMMITTEE)
  createdAt DateTime @default(now())

  createdTasks Task[] @relation("CreatedTasks")
  auditEvents  AuditEvent[]
}

model Scheme {
  id        String   @id @default(cuid())
  ctsNumber String?
  name      String
  address   String?
  createdAt DateTime @default(now())

  tasks Task[]
}

model Task {
  id                 String     @id @default(cuid())
  taskCode           String     @unique
  schemeId           String
  scheme             Scheme     @relation(fields: [schemeId], references: [id], onDelete: Cascade)
  requirementRef     String?
  category           String
  frequency          String
  areaAsset          String
  responsibleParty   String?
  requirement        String
  status             TaskStatus @default(SCHEDULED)
  priority           Priority   @default(NORMAL)
  dueDate            DateTime?
  actionedAt         DateTime?
  verifiedBy         String?
  verifiedDate       DateTime?
  actionTaken        String?
  exceptionNotes     String?
  followUpRequired   Boolean    @default(false)
  followUpDue        DateTime?
  followUpNotes      String?
  calendarEventId    String?
  createdById        String?
  createdBy          User?      @relation("CreatedTasks", fields: [createdById], references: [id])
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  checklistItems     ChecklistItem[]
  documents          EvidenceFile[]
  financialControl   FinancialControl?
  auditEvents        AuditEvent[]

  @@index([schemeId])
  @@index([status])
  @@index([dueDate])
  @@index([category])
}

model ChecklistItem {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  text      String
  done      Boolean  @default(false)
  note      String?
  sortOrder Int      @default(0)
  completedAt DateTime?

  @@index([taskId])
}

model EvidenceFile {
  id             String           @id @default(cuid())
  taskId         String
  task           Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  category       DocumentCategory @default(OTHER)
  originalName   String
  systemName     String
  mimeType       String?
  sizeBytes      Int?
  storagePath    String
  caption        String?
  notes          String?
  visibility     Visibility       @default(COMMITTEE_ONLY)
  reviewStatus   String           @default("Uploaded")
  uploadedBy     String?
  uploadedAt     DateTime         @default(now())

  @@index([taskId])
  @@index([category])
}

model FinancialControl {
  id                     String        @id @default(cuid())
  taskId                 String        @unique
  task                   Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)

  quoteContractor         String?
  quoteNumber             String?
  quoteDate               DateTime?
  quoteAmountExGst        Float?
  quoteGst                Float?
  quoteTotalIncGst        Float?

  invoiceContractor       String?
  invoiceNumber           String?
  invoiceDate             DateTime?
  invoiceAmountExGst      Float?
  invoiceGst              Float?
  invoiceTotalIncGst      Float?

  allowedVariancePercent  Float         @default(0)
  allowedVarianceAmount   Float         @default(0)
  varianceAmount          Float         @default(0)
  variancePercent         Float         @default(0)

  variationApproved       Boolean       @default(false)
  variationApprovedBy     String?
  variationApprovedAt     DateTime?
  variationNotes          String?

  gstCheckStatus          String        @default("Not assessed")
  duplicateInvoiceStatus  String        @default("Not checked")
  paymentStatus           PaymentStatus @default(PENDING)
  paymentBlockReason      String?
  readyForPayment         Boolean       @default(false)

  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  @@index([paymentStatus])
  @@index([invoiceNumber])
}

model AuditEvent {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  eventType String
  detail    String
  createdAt DateTime @default(now())

  @@index([taskId])
}
