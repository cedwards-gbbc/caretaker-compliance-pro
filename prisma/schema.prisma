datasource db {

  provider = "postgresql"

  url      = env("DATABASE_URL")

}

generator client {

  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  COMMITTEE
  CARETAKER
  STRATA_MANAGER
  CONTRACTOR
  OWNER_VIEWER
}

enum TaskStatus {
  SCHEDULED
  ACTIONED
  COMPLETED
  NEEDS_FOLLOW_UP
  ESCALATED_TO_COMMITTEE
  NOT_REQUIRED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum PaymentStatus {
  PASS
  WARNING
  BLOCKED
  PENDING
}

enum DocumentCategory {
  PHOTO_EVIDENCE
  QUOTE
  INVOICE
  VARIATION_APPROVAL
  COMMITTEE_APPROVAL
  CONTRACTOR_REPORT
  COMPLIANCE_CERTIFICATE
  EMAIL_EVIDENCE
  OTHER
}


enum DefectStatus {
  REPORTED
  UNDER_REVIEW
  INSPECTION_REQUIRED
  QUOTE_REQUIRED
  AWAITING_APPROVAL
  APPROVED_FOR_REPAIR
  REPAIR_SCHEDULED
  REPAIR_COMPLETED
  VERIFICATION_REQUIRED
  MONITORING
  CLOSED
  REJECTED
}

enum RiskRating {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Urgency {
  NORMAL
  URGENT
  EMERGENCY
}

enum DefectTaskPurpose {
  INSPECTION
  QUOTE
  APPROVAL
  REPAIR
  FOLLOW_UP
  MONITORING
  OTHER
}

enum Visibility {
  INTERNAL_ONLY
  COMMITTEE_ONLY
  OWNER_VISIBLE
  RESTRICTED
}

model User {
  id        String   @id @default(cuid())
  fullName  String
  email     String   @unique
  role      UserRole @default(COMMITTEE)
  createdAt DateTime @default(now())

  createdTasks Task[] @relation("CreatedTasks")
  auditEvents  AuditEvent[]
}

model Scheme {
  id        String   @id @default(cuid())
  ctsNumber String?
  name      String
  address   String?
  createdAt DateTime @default(now())

  tasks Task[]
  defects Defect[]
}

model Task {
  id                 String     @id @default(cuid())
  taskCode           String     @unique
  schemeId           String
  scheme             Scheme     @relation(fields: [schemeId], references: [id], onDelete: Cascade)
  requirementRef     String?
  category           String
  frequency          String
  areaAsset          String
  responsibleParty   String?
  requirement        String
  status             TaskStatus @default(SCHEDULED)
  priority           Priority   @default(NORMAL)
  dueDate            DateTime?
  actionedAt         DateTime?
  verifiedBy         String?
  verifiedDate       DateTime?
  actionTaken        String?
  exceptionNotes     String?
  followUpRequired   Boolean    @default(false)
  followUpDue        DateTime?
  followUpNotes      String?
  calendarEventId    String?
  isDeleted          Boolean    @default(false)
  deletedAt          DateTime?
  deletedBy          String?
  deletedReason      String?
  startTime          String?
  endTime            String?
  contractorCompany  String?
  assignedCompanyId   String?
  assignedCompany     ContractorCompany? @relation(fields: [assignedCompanyId], references: [id])
  quoteRequired      Boolean    @default(false)
  committeeApprovalRequired Boolean @default(false)
  dayDriveFolderId   String?
  dayDriveFolderUrl  String?
  taskDriveFolderId  String?
  taskDriveFolderUrl String?
  photoFolderUrl     String?
  documentFolderUrl  String?
  googleDriveSyncStatus String?
  lastDriveSyncAt    DateTime?
  createdById        String?
  createdBy          User?      @relation("CreatedTasks", fields: [createdById], references: [id])
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  checklistItems     ChecklistItem[]
  documents          EvidenceFile[]
  financialControl   FinancialControl?
  auditEvents        AuditEvent[]
  defectLinks        DefectTaskLink[]

  @@index([schemeId])
  @@index([status])
  @@index([isDeleted])
  @@index([dueDate])
  @@index([category])
}

model ChecklistItem {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  text      String
  done      Boolean  @default(false)
  note      String?
  sortOrder Int      @default(0)
  completedAt DateTime?

  @@index([taskId])
}

model EvidenceFile {
  id             String           @id @default(cuid())
  taskId         String
  task           Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  category       DocumentCategory @default(OTHER)
  originalName   String
  systemName     String
  mimeType       String?
  sizeBytes      Int?
  storagePath    String
  caption        String?
  notes          String?
  visibility     Visibility       @default(COMMITTEE_ONLY)
  reviewStatus   String           @default("Uploaded")
  uploadedBy     String?
  uploadedAt     DateTime         @default(now())

  @@index([taskId])
  @@index([category])
}

model FinancialControl {
  id                     String        @id @default(cuid())
  taskId                 String        @unique
  task                   Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)

  quoteContractor         String?
  quoteNumber             String?
  quoteDate               DateTime?
  quoteAmountExGst        Float?
  quoteGst                Float?
  quoteTotalIncGst        Float?

  invoiceContractor       String?
  invoiceNumber           String?
  invoiceDate             DateTime?
  invoiceAmountExGst      Float?
  invoiceGst              Float?
  invoiceTotalIncGst      Float?

  allowedVariancePercent  Float         @default(0)
  allowedVarianceAmount   Float         @default(0)
  varianceAmount          Float         @default(0)
  variancePercent         Float         @default(0)

  variationApproved       Boolean       @default(false)
  variationApprovedBy     String?
  variationApprovedAt     DateTime?
  variationNotes          String?

  gstCheckStatus          String        @default("Not assessed")
  duplicateInvoiceStatus  String        @default("Not checked")
  paymentStatus           PaymentStatus @default(PENDING)
  paymentBlockReason      String?
  readyForPayment         Boolean       @default(false)

  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  @@index([paymentStatus])
  @@index([invoiceNumber])
}

model AuditEvent {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  eventType String
  detail    String
  createdAt DateTime @default(now())

  @@index([taskId])
}


model Defect {
  id                         String       @id @default(cuid())
  defectCode                 String       @unique
  schemeId                   String
  scheme                     Scheme       @relation(fields: [schemeId], references: [id], onDelete: Cascade)

  title                      String
  description                String
  location                   String?
  lotReference               String?
  assetCategory              String?
  commonPropertyImpact       Boolean      @default(true)

  riskRating                 RiskRating   @default(MEDIUM)
  urgency                    Urgency      @default(NORMAL)
  status                     DefectStatus @default(REPORTED)

  reportedBy                 String?
  reportedDate               DateTime     @default(now())
  responsibleParty           String?
  insuranceRelevant          Boolean      @default(false)
  legalSensitive             Boolean      @default(false)
  committeeApprovalRequired  Boolean      @default(false)
  ownerCommunicationRequired Boolean      @default(false)

  estimatedCost              Float?
  actualCost                 Float?
  fundingSource              String?

  evidenceFolderUrl          String?
  photoFolderUrl             String?
  documentFolderUrl          String?

  closureEvidenceRequired    Boolean      @default(true)
  closureTaskId              String?
  closedAt                   DateTime?
  closedBy                   String?
  closureNotes               String?
  reopenedAt                 DateTime?
  reopenReason               String?

  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt

  taskLinks                  DefectTaskLink[]
  auditEvents                DefectAuditEvent[]

  @@index([schemeId])
  @@index([status])
  @@index([riskRating])
  @@index([urgency])
  @@index([reportedDate])
}

model DefectTaskLink {
  id            String            @id @default(cuid())
  defectId      String
  taskId        String
  purpose       DefectTaskPurpose @default(OTHER)
  isClosureTask Boolean           @default(false)
  notes         String?
  createdAt     DateTime          @default(now())

  defect        Defect            @relation(fields: [defectId], references: [id], onDelete: Cascade)
  task          Task              @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([defectId, taskId])
  @@index([defectId])
  @@index([taskId])
  @@index([purpose])
}

model DefectAuditEvent {
  id        String   @id @default(cuid())
  defectId  String
  defect    Defect   @relation(fields: [defectId], references: [id], onDelete: Cascade)
  eventType String
  detail    String
  createdAt DateTime @default(now())

  @@index([defectId])
}


model ContractorCompany {
  id              String   @id @default(cuid())

  companyName     String   @unique
  websiteUrl      String
  logoUrl         String?
  companyPhone    String
  tradeType       String?
  contactName     String?
  email           String?
  abn             String?
  licenceExpiry   DateTime?
  insuranceExpiry DateTime?
  active          Boolean  @default(true)

  tasks           Task[]
  accessGrants    ContractorAccessGrant[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyName])
  @@index([active])
}


model ContractorAccessGrant {
  id            String   @id @default(cuid())
  companyId     String
  company       ContractorCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  pinCode       String
  accessToken   String   @unique
  taskId        String?
  taskCode      String?
  accessScope   String   @default("TASK_ONLY")
  expiresAt     DateTime
  active        Boolean  @default(true)

  createdBy     String?
  lastUsedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
  @@index([pinCode])
  @@index([active])
  @@index([expiresAt])
}

